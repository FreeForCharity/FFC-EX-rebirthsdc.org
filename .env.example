# Google Analytics 4 Measurement ID
# Get this from: analytics.google.com → Admin → Data Streams → your stream → Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta Pixel ID (Facebook)
# Get this from: business.facebook.com → Events Manager → your pixel → Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=XXXXXXXXXXXXXXX

# Microsoft Clarity Project ID
# Get this from: clarity.microsoft.com → your project → Settings → Clarity ID
NEXT_PUBLIC_CLARITY_PROJECT_ID=XXXXXXXXXX
